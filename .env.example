# ============================================================
#  AY-automatisering — Environment Variables
#  Kopieer dit bestand naar .env en vul je eigen keys in.
#  NOOIT het .env bestand committen naar git.
# ============================================================

# --- AI Models ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# --- Video Generatie ---
PEXELS_API_KEY=...             # Gratis — https://www.pexels.com/api/ (stock footage met echte mensen)
KLING_API_KEY=...
RUNWAY_API_KEY=...
DID_API_KEY=...

# --- Audio ---
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...         # Default stem ID

# --- Database ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_KEY=...

# --- Social Kanalen ---
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
TIKTOK_ACCESS_TOKEN=...

# --- Systeem ---
ENVIRONMENT=development         # development | production
LOG_LEVEL=INFO
MAX_COST_PER_CAMPAIGN_USD=1.00  # Hard limiet per campagne
APPROVAL_REQUIRED=true          # Altijd true — nooit uitschakelen
EXPERIMENTS_ENABLED=false       # true = A/B test varianten bij elke campagne

# --- Authenticatie ---
AUTH_ENABLED=false              # true in productie; false in development (geen API key vereist)

# --- Repository Backend ---
REPO_BACKEND=file              # file (default) of sqlite — zie scripts/migrate_to_sqlite.py
