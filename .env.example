# ============================================================
#  AY-automatisering - Environment Variables
#  Kopieer dit bestand naar .env en vul je eigen keys in.
#  NOOIT het .env bestand committen naar git.
# ============================================================

# --- AI Models ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# --- Video Generatie ---
PEXELS_API_KEY=...
PIXABAY_API_KEY=...
KLING_API_KEY=...
RUNWAY_API_KEY=...
DID_API_KEY=...

# --- Audio ---
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
ELEVENLABS_CLONE_VOICE_ID=...

# --- Database ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...   # Alias die ook ondersteund wordt

# --- Social Kanalen ---
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
TIKTOK_ACCESS_TOKEN=...
TIKTOK_REFRESH_TOKEN=...
TIKTOK_POST_MODE=INBOX

# --- Systeem ---
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_COST_PER_CAMPAIGN_USD=1.00
APPROVAL_REQUIRED=true
AUTO_APPROVE_THRESHOLD=80
DAILY_POSTS_PER_APP=2
EXPERIMENTS_ENABLED=false

# --- Authenticatie ---
AUTH_ENABLED=false

# --- Repository Backend ---
REPO_BACKEND=supabase
